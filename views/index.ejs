<!DOCTYPE html>
<html lang="en" data-theme="retro">
<head>
    <meta charset="UTF-8">
    <title>Grand Line Registry - <%= title %></title>
    <link rel="stylesheet" href="main.css">
</head>
<body class="p-4 container mx-auto">
    <%- include('partials/navbar') %>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% for (let member of crew) { %>
            <div class="card bg-base-100 shadow-xl border-t-4 border-primary">
                <div class="card-body">
                    <h2 class="card-title text-2xl font-black uppercase"><%= member.name %></h2>
                    <p><strong>Role:</strong> <%= member.role %></p>
                    <p><strong>Fruit:</strong> <%= member.devilFruit %></p>
                    <p class="text-secondary text-xl font-mono mt-2"><%= member.bounty %> Berries</p>
                    
                    <div class="card-actions justify-end mt-4">
                        <% if (member.status === 'active') { %>
                            <div class="badge badge-success p-3 text-white font-bold">Active</div>
                        <% } else if (member.status === 'inactive') { %>
                            <div class="badge badge-error p-3 text-white font-bold">Bounty Frozen</div>
                        <% } else { %>
                            <div class="badge badge-warning p-3 font-bold">Pending Approval</div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>